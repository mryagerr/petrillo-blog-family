---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>👋 Welcome to the Petrillo Family blog!</h1>
			<p>
				This is our little corner of the web where we share our adventures, milestones, and
				memories. Big trips, birthdays, and everything in between.
			</p>
			<p>
				First up: we're celebrating <strong>Michael's 40th birthday</strong> with a ten-day road
				trip through Las Vegas and Zion. Head over to the <a href="/blog">blog</a> to see the full
				itinerary.
			</p>
		</main>
		<Footer />
	</body>
</html>
