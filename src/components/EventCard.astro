---
import type { EventEntry } from "../lib/events";
import { mayRevealGallery } from "../lib/events";
import TypeTag from "./TypeTag.astro";
import EventWhen from "./EventWhen.astro";
import EventLocation from "./EventLocation.astro";
import CalendarButtons from "./CalendarButtons.astro";
import RsvpButton from "./RsvpButton.astro";

interface Props {
	event: EventEntry;
	variant: "upcoming" | "past";
}

const { event, variant } = Astro.props;
const { title, description, host, heroImage, recap, gallery } = event.data;
const url = `/events/${event.id}/`;
const showGallery = variant === "past" && mayRevealGallery() && gallery.length > 0;
---

<article class="card">
	{
		heroImage && (
			<a href={url} class="card-image" tabindex="-1" aria-hidden="true">
				<img src={heroImage} alt="" loading="lazy" />
			</a>
		)
	}
	<div class="card-body">
		<TypeTag type={event.data.type} />
		<h3 class="card-title"><a href={url}>{title}</a></h3>
		<EventWhen event={event} />
		<EventLocation event={event} />
		{host && <p class="host">Hosted by {host}</p>}
		<p class="desc">{description}</p>
		{variant === "past" && recap && <p class="recap">“{recap}”</p>}

		{
			showGallery && (
				<div class="gallery">
					{gallery.map((photo) => (
						<img src={photo.src} alt={photo.alt} loading="lazy" />
					))}
				</div>
			)
		}

		{
			variant === "upcoming" && (
				<div class="card-actions">
					<RsvpButton event={event} />
					<CalendarButtons event={event} />
				</div>
			)
		}

		<a href={url} class="details-link">
			{variant === "past" ? "See photos & recap" : "See full details"} →
		</a>
	</div>
</article>

<style>
	.card {
		display: flex;
		flex-direction: column;
		background: white;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 1px 3px rgba(var(--gray), 15%);
		transition: 0.15s ease;
	}
	.card:hover {
		box-shadow: var(--box-shadow);
	}
	.card-image img {
		display: block;
		width: 100%;
		aspect-ratio: 2 / 1;
		object-fit: cover;
		border-radius: 0;
	}
	.card-body {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding: 1.25rem 1.5rem 1.5rem;
	}
	.card-title {
		margin: 0.1rem 0 0;
		font-size: 1.6rem;
		line-height: 1.15;
	}
	.card-title a {
		color: rgb(var(--black));
		text-decoration: none;
	}
	.card-title a:hover {
		color: var(--accent);
	}
	.host {
		margin: 0;
		color: rgb(var(--gray));
		font-style: italic;
	}
	.desc {
		margin: 0.2rem 0 0;
	}
	.recap {
		margin: 0;
		padding-left: 0.9rem;
		border-left: 3px solid var(--accent);
		color: rgb(var(--gray-dark));
		font-style: italic;
	}
	.gallery {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
		gap: 0.5rem;
	}
	.gallery img {
		width: 100%;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		border-radius: 10px;
	}
	.card-actions {
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		margin-top: 0.4rem;
		padding-top: 1rem;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.details-link {
		margin-top: 0.3rem;
		font-weight: 700;
		text-decoration: none;
	}
	.details-link:hover {
		text-decoration: underline;
	}
</style>
