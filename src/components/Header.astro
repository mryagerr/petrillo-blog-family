---
import { SITE_TITLE } from "../consts";
---

<header>
	<div class="wrap">
		<a class="brand" href="/">
			<span class="crest" aria-hidden="true">🌿</span>
			<span class="name">{SITE_TITLE}</span>
		</a>
		<p class="tagline">Family gatherings, big and small</p>
	</div>
</header>

<style>
	header {
		background: var(--surface);
		border-bottom: 1px solid var(--hairline);
	}
	.wrap {
		max-width: 900px;
		margin: 0 auto;
		padding: 1.1em 1.25em;
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.35em 0.9em;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		text-decoration: none;
		color: var(--ink);
	}
	.crest {
		font-size: 1.6rem;
	}
	.name {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.7rem;
		line-height: 1;
	}
	.tagline {
		margin: 0;
		color: var(--ink-soft);
		font-size: 1rem;
	}
</style>
