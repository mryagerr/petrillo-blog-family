---
import { SITE_TITLE } from "../consts";
---

<header>
	<nav>
		<a href="/" class="site-title">
			<span aria-hidden="true">🌿</span>
			{SITE_TITLE}
		</a>
		<div class="links">
			<a href="/#upcoming">Upcoming</a>
			<a href="/#past">Past</a>
			<a href="/calendar.ics" class="subscribe">Subscribe</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5rem;
		max-width: 1040px;
		margin: 0 auto;
	}
	.site-title {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.9em 0;
		font-size: 1.15rem;
		font-weight: 700;
		color: rgb(var(--black));
		text-decoration: none;
	}
	.links {
		display: flex;
		gap: 0.3rem;
	}
	.links a {
		padding: 0.9em 0.7em;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-weight: 700;
		border-bottom: 3px solid transparent;
	}
	.links a:hover {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}
	.links a.subscribe {
		color: var(--accent-dark);
	}
	@media (max-width: 480px) {
		.links a {
			padding: 0.6em 0.5em;
			font-size: 0.95rem;
		}
	}
</style>
