---
import {
	RSVP_INSTRUCTION,
	PRIVACY_NOTE,
	ORGANIZER_NAME,
	CONTACT_URL,
} from "../consts";

const today = new Date();
---

<footer>
	<div class="info-strip">
		<p class="info-item">
			<span aria-hidden="true">✉️</span>
			<span><strong>How to RSVP:</strong> {RSVP_INSTRUCTION}</span>
		</p>
		<p class="info-item">
			<span aria-hidden="true">🔒</span>
			<span><strong>A note on privacy:</strong> {PRIVACY_NOTE}</span>
		</p>
		<p class="info-item">
			<span aria-hidden="true">💬</span>
			<span>
				Questions? <a href={CONTACT_URL}>Contact {ORGANIZER_NAME}</a>.
			</span>
		</p>
	</div>
	<p class="copyright">&copy; {today.getFullYear()} The Petrillo Family</p>
</footer>

<style>
	footer {
		padding: 2.5rem 1.5rem 3rem;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray-dark));
	}
	.info-strip {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
		max-width: 1040px;
		margin: 0 auto;
	}
	.info-item {
		display: flex;
		gap: 0.6rem;
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.5;
	}
	.copyright {
		margin: 2rem 0 0;
		text-align: center;
		font-size: 0.85rem;
		color: rgb(var(--gray));
	}
	@media (max-width: 720px) {
		.info-strip {
			grid-template-columns: 1fr;
			gap: 1rem;
		}
	}
</style>
