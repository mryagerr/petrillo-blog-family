---
import { CONTACT_URL, CONTACT_LABEL, ORGANIZER_NAME } from "../consts";
const year = new Date().getFullYear();
---

<footer>
	<div class="strip">
		<!-- 1. How to RSVP -->
		<p class="item">
			<span class="ico" aria-hidden="true">✉️</span>
			<span><strong>To RSVP:</strong> tap the “Let&nbsp;{ORGANIZER_NAME}&nbsp;know”
				button on any event, or use <a href={CONTACT_URL}>{CONTACT_LABEL}</a>.</span>
		</p>
		<!-- 2. Privacy note (so a missing address reads as intentional) -->
		<p class="item">
			<span class="ico" aria-hidden="true">🔒</span>
			<span>We keep home addresses private — you&rsquo;ll get the full
				address after you RSVP.</span>
		</p>
		<!-- 3. Questions? Contact path -->
		<p class="item">
			<span class="ico" aria-hidden="true">💬</span>
			<span>Questions? <a href={CONTACT_URL}>Contact {ORGANIZER_NAME}</a>.</span>
		</p>
	</div>
	<p class="copy">With love, the Petrillo family · {year}</p>
</footer>

<style>
	footer {
		margin-top: 3em;
		background: var(--surface);
		border-top: 1px solid var(--hairline);
		padding: 2em 1.25em 3em;
	}
	.strip {
		max-width: 900px;
		margin: 0 auto;
		display: grid;
		gap: 0.9em;
	}
	.item {
		margin: 0;
		display: flex;
		gap: 0.6em;
		align-items: flex-start;
		color: var(--ink-soft);
		font-size: 1.02rem;
		line-height: 1.5;
	}
	.ico {
		flex: none;
		font-size: 1.2rem;
	}
	.item a {
		color: var(--accent-ink);
		font-weight: 700;
	}
	.copy {
		max-width: 900px;
		margin: 1.5em auto 0;
		text-align: center;
		color: var(--ink-faint);
		font-size: 0.95rem;
	}
	@media (min-width: 700px) {
		.strip {
			grid-template-columns: repeat(3, 1fr);
			gap: 1.5em;
		}
	}
</style>
