---
import { IS_GATED, GATE_PASSWORD, SITE_TITLE } from "../consts";
// This overlay only renders in gated mode. It is LIGHT-TOUCH obfuscation:
// it keeps casual visitors out, but the check runs in the browser, so it is
// not real security. For genuine privacy, also put the deployment behind
// Cloudflare Access or Basic Auth (see the README).
---

{
	IS_GATED && (
		<div id="gate" class="gate" hidden>
			<div class="box">
				<div class="crest" aria-hidden="true">🌿</div>
				<h1>{SITE_TITLE}</h1>
				<p>This page is just for family & invited friends. Enter the shared
					password to come on in.</p>
				<form id="gate-form">
					<label class="sr-only" for="gate-pass">Shared password</label>
					<input
						id="gate-pass"
						type="password"
						autocomplete="off"
						placeholder="Shared password"
					/>
					<button type="submit">Enter</button>
				</form>
				<p id="gate-error" class="err" hidden>That&rsquo;s not it — try again.</p>
				<p class="hint">Don&rsquo;t have it? Just ask the family organizer.</p>
			</div>
		</div>
	)
}

{
	IS_GATED && (
		<script is:inline define:vars={{ pass: GATE_PASSWORD }}>
			(function () {
				const KEY = "petrillo-gate-ok";
				const gate = document.getElementById("gate");
				if (!gate) return;
				const unlock = () => {
					gate.remove();
					document.documentElement.classList.remove("gate-locked");
				};
				if (sessionStorage.getItem(KEY) === "1") {
					unlock();
					return;
				}
				document.documentElement.classList.add("gate-locked");
				gate.hidden = false;
				const form = document.getElementById("gate-form");
				const input = document.getElementById("gate-pass");
				const err = document.getElementById("gate-error");
				form.addEventListener("submit", function (e) {
					e.preventDefault();
					if (input.value === pass) {
						sessionStorage.setItem(KEY, "1");
						unlock();
					} else {
						err.hidden = false;
						input.value = "";
						input.focus();
					}
				});
				input.focus();
			})();
		</script>
	)
}

<style>
	:global(html.gate-locked) {
		overflow: hidden;
	}
	:global(html.gate-locked body) {
		filter: blur(6px);
	}
	.gate {
		position: fixed;
		inset: 0;
		z-index: 1000;
		display: grid;
		place-items: center;
		background: var(--gate-bg);
		padding: 1.5em;
	}
	.box {
		background: var(--surface);
		border-radius: 20px;
		padding: 2em 1.8em;
		max-width: 24em;
		width: 100%;
		text-align: center;
		box-shadow: var(--card-shadow);
	}
	.crest {
		font-size: 2.5rem;
	}
	.box h1 {
		font-family: var(--font-display);
		font-size: 1.8rem;
		margin: 0.2em 0 0.3em;
	}
	.box p {
		color: var(--ink-soft);
		margin: 0.4em 0;
	}
	form {
		display: flex;
		gap: 0.5em;
		margin: 1em 0 0.5em;
	}
	input {
		flex: 1;
		padding: 0.7em 0.9em;
		font-size: 1.05rem;
		border: 1px solid var(--hairline-strong);
		border-radius: 10px;
		background: var(--sunken);
		color: var(--ink);
	}
	button {
		padding: 0.7em 1.2em;
		font-size: 1.05rem;
		font-weight: 700;
		border: none;
		border-radius: 10px;
		background: var(--accent);
		color: #fff;
		cursor: pointer;
	}
	button:hover {
		background: var(--accent-strong);
	}
	.err {
		color: var(--danger);
		font-weight: 700;
	}
	.hint {
		font-size: 0.9rem;
	}
</style>
